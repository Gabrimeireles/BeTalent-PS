# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app

# Gateways
# Local app + docker mocks: keep localhost
# Full docker compose app: set GATEWAY_MOCK_HOST=gateways-mock
GATEWAY_MOCK_HOST=localhost
GATEWAY1_PORT=3001
GATEWAY2_PORT=3002
# Optional explicit URLs (override host/port composition)
# GATEWAY1_BASE_URL=http://localhost:3001
# GATEWAY2_BASE_URL=http://localhost:3002
